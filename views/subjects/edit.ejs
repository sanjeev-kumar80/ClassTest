<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>



<%- include('../partials/navbar') %>

<h2>Edit Subject</h2>

<form action="/subject/<%= subject._id %>?_method=PUT" method="POST">
    <input type="text" name="subjectName" value="<%= subject.subjectName %>">
    <input type="number" name="price" value="<%= subject.price %>">
    <input type="text" name="image" value="<%= subject.image %>">
    <input type="number" name="units" value="<%= subject.units %>">

    <button>Update</button>
</form>